{
  "_comment": "Copy to chat_kiosk.json and edit. archive_dir and outbox_dir are required. All other keys are optional.",

  "archive_dir":    "/path/to/archiver/archives/<conversation-id>",
  "attachments_dir": "/path/to/archiver/archives/<conversation-id>/attachments",
  "outbox_dir":     "/path/to/filesender/outbox/<conversation-id>",

  "poll_interval":           1.0,
  "slideshow_interval":      4.0,
  "video_autoplay_delay":    3,
  "quick_messages":          ["Yes", "No", "Perhaps"],
  "idle_notification_delay": 1,
  "led_pin_1":               5,
  "led_pin_2":               6,
  "led_blink_interval":      10
}
